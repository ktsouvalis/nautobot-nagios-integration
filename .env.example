NAUTOBOT_TOKEN=
SNMP_COMMUNITY_CISCO=
SNMP_COMMUNITY_DEFAULT=
NAUTOBOT_URL=
NAGIOS_WEB_URL=
NAGIOS_SSH_HOST=
NAGIOS_SSH_USER=
NAGIOS_SSH_PASSWORD=
NAGIOS_SSH_PORT=
# Set to true to enforce known_hosts verification (requires ~/.ssh/known_hosts entry)
NAGIOS_SSH_VERIFY_HOST_KEYS=false

# SNMPv3 credentials (only needed if snmp.v3_roles is non-empty in config.yaml)
SNMP_V3_USER=
SNMP_V3_SEC_LEVEL=authPriv
SNMP_V3_AUTH_PROTO=SHA
SNMP_V3_AUTH_PASS=
SNMP_V3_PRIV_PROTO=AES
SNMP_V3_PRIV_PASS=